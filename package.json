{
  "name": "ai-ng-kit-claude",
  "version": "2.8.98",
  "type": "module",
  "description": "Harness Engineering Agent for Claude Code — 21 named agents, 41 skills, AING-DR Consensus Planning, AI Pipeline, 696 tests, 31 Innovations",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sangwookp9591/ai-ng-kit-claude.git"
  },
  "homepage": "https://github.com/sangwookp9591/ai-ng-kit-claude#readme",
  "keywords": [
    "claude-code",
    "ai-agents",
    "aing",
    "harness",
    "pdca",
    "tdd",
    "team-pipeline",
    "multi-agent"
  ],
  "author": "sangwookp9591",
  "scripts": {
    "build": "tsc && npm run build:skills",
    "build:ts": "tsc",
    "build:skills": "node dist/scripts/build/gen-skill-docs.js",
    "build:all": "node dist/scripts/build/generate-all.js",
    "build:check": "node dist/scripts/build/generate-all.js --check",
    "build:force": "node dist/scripts/build/generate-all.js --force",
    "check:skills": "node dist/scripts/build/check-freshness.js",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc",
    "test": "node --test tests/*.test.mjs tests/eval/*.mjs tests/unit/land-orchestrator.test.mjs",
    "test:unit": "npx vitest run",
    "test:e2e": "npx tsx --test tests/e2e/skills/*.e2e.test.ts tests/e2e/browse/*.test.ts",
    "test:teaching": "npx tsx --test tests/teaching/*.test.ts",
    "test:all": "npm run test:unit && npm test && npm run test:e2e && npm run test:teaching",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "agents/",
    "skills/",
    "hooks/",
    "dist/",
    "browse/dist/",
    "templates/",
    "images/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@ast-grep/napi": "^0.42.0"
  }
}
